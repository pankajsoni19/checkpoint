# ── Frontend (build-time — baked into the bundle by Vite) ────────────────────
# Base URL for API calls. Leave blank when the SPA is served by the same server.
VITE_API_BASE_URL=

# Show the email/password login & signup forms. Set to "false" to offer
# Google sign-in only. Defaults to enabled when unset.
VITE_ENABLE_PASSWORD_AUTH=true

# Single-tenant lock. When set, this org is created automatically, every user
# belongs to it, and no other organizations can be created. Leave unset for
# multi-tenant mode (users create/join their own organizations).
VITE_ORG=

# Google client id for the in-browser Google Identity Services button.
VITE_GOOGLE_CLIENT_ID=

# ── Backend (runtime) ────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# Public origin used to build password-reset links (defaults to the request origin).
APP_BASE_URL=

# Session cookie signing secret (stable across restarts).
SESSION_SECRET=change-me
# Encryption key for stored connection/SMTP secrets (defaults to SESSION_SECRET).
APP_SECRET_KEY=

# Google: the server verifies the ID token the client sends against this id.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# MySQL metadata store (the app's own database). Either APP_DATABASE_URL …
APP_DATABASE_URL=mysql://checkpoint:checkpoint@localhost:3306/checkpoint
# … or the individual parts (used if APP_DATABASE_URL is unset):
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=checkpoint
# DB_PASSWORD=checkpoint
# DB_NAME=checkpoint
